# CipherPipe configuration
CP_PORT=8700
CP_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band
CP_KEY_FILE=nostr.key
CP_RELAY_CONFIG=~/.cipherpipe/relays.json
CP_FILE_MAX_SIZE=104857600

# AI auto-reply backend: ollama | openai | anthropic
CP_AI_BACKEND=anthropic

# Ollama
CP_AI_OLLAMA_URL=http://localhost:11434
CP_AI_OLLAMA_MODEL=qwen3:14b

# OpenAI-compatible
CP_AI_OPENAI_URL=https://api.deepseek.com
CP_AI_OPENAI_KEY=sk-xxx
CP_AI_OPENAI_MODEL=deepseek-chat

# Anthropic-compatible (DeepSeek/GLM)
CP_AI_ANTHROPIC_URL=https://api.deepseek.com/anthropic
CP_AI_ANTHROPIC_KEY=sk-xxx
CP_AI_ANTHROPIC_MODEL=deepseek-v4-flash
